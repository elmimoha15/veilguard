{
  "name": "veilguard",
  "version": "0.2.0",
  "description": "MCP security scanner for AI-assisted development. Catches vulnerabilities in AI-generated code.",
  "type": "module",
  "bin": {
    "veilguard-cli": "dist/cli.js",
    "veilguard-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "patterns/",
    "templates/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "vibe-coding",
    "supabase",
    "rls",
    "secrets",
    "vulnerabilities",
    "claude-code",
    "cursor",
    "windsurf"
  ],
  "author": "Mohamed Elmi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elmimoha15/veilguard.git"
  },
  "homepage": "https://veilguard.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
